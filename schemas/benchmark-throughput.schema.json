{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema_version", "generated_at", "mode", "first_call", "noop_call", "profile"],
  "properties": {
    "schema_version": {"type": "string"},
    "generated_at": {"type": "string"},
    "mode": {"type": "string", "const": "throughput"},
    "first_call": {"type": "object"},
    "noop_call": {"type": "object"},
    "profile": {"type": "object"}
  }
}
